# Neon Postgres connection string
# Format: postgresql://user:pass@host.neon.tech/db?sslmode=require
DATABASE_URL=

# Ethereum RPC URL (Alchemy / QuickNode recommended for archive reads)
# Public fallbacks are used if unset, but archive-heavy scans will be slow/rate-limited
ETH_RPC_URL=

# Optional: secret token required on cron endpoints (Bearer <token>)
CRON_SECRET=
