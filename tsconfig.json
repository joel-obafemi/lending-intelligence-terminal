{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    // The Cloudflare Worker is a separate project with its own TypeScript
    // setup — it imports Cloudflare's `ScheduledController` / `ExecutionContext`
    // ambient types which aren't present in the main Next.js compile.
    "worker",
    // Same situation for the alerts Worker — has its own tsconfig and
    // depends on @cloudflare/workers-types ambients that the Next.js
    // compile does not load.
    "alerts",
    // The scripts/ folder holds one-shot CLI operator tools (research
    // queries, snapshot capture, cover rendering, etc.) that the app/
    // and lib/ code never imports. They lazy-import optional dev deps
    // (playwright for cover rendering, etc.) and rely on loose typing
    // patterns around viem readContract overloads that conflict with
    // the strict tsconfig used for the built app. Excluded from the
    // Next.js typecheck wholesale; type-check them individually with
    // `npx tsx <file>` before publishing if needed.
    "scripts"
  ]
}
