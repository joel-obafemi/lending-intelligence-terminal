{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": [
    "node_modules",
    // The Cloudflare Worker is a separate project with its own TypeScript
    // setup — it imports Cloudflare's `ScheduledController` / `ExecutionContext`
    // ambient types which aren't present in the main Next.js compile.
    "worker",
    // Cover-rendering script lazy-imports playwright (an optional dev
    // dep). Authors install it on demand before rendering Issue #N's
    // covers; the main Next.js build doesn't need to typecheck against
    // it.
    "scripts/render-covers.ts"
  ]
}
